# Copy to .env and adjust. All vars are optional; defaults run fully offline.

# --- storage ---
# LEDGERFLOW_DATABASE_URL=sqlite:///./ledgerflow.db
# LEDGERFLOW_DATABASE_URL=postgresql+psycopg2://ledger:ledger@localhost:5432/ledgerflow

# --- queue ---
# LEDGERFLOW_QUEUE_BACKEND=inprocess        # inprocess | redis
# LEDGERFLOW_REDIS_URL=redis://localhost:6379/0

# --- LLM provider (default 'stub' needs no keys) ---
# LEDGERFLOW_LLM_PROVIDER=stub              # stub | openai | gemini
# LEDGERFLOW_OPENAI_API_KEY=sk-...
# LEDGERFLOW_OPENAI_MODEL=gpt-4o-mini
# LEDGERFLOW_GEMINI_API_KEY=...
# LEDGERFLOW_GEMINI_MODEL=gemini-1.5-flash

# --- the gate (P1) ---
# LEDGERFLOW_CONFIDENCE_THRESHOLD=0.85
# LEDGERFLOW_VENDOR_MATCH_THRESHOLD=85
# LEDGERFLOW_AMOUNT_TOLERANCE=0.02

# --- retries / dead-letter (P4) ---
# LEDGERFLOW_MAX_ATTEMPTS=3
# LEDGERFLOW_RETRY_BACKOFF_BASE=0.5

# --- ingest ---
# LEDGERFLOW_WATCH_DIR=./invoices
# LEDGERFLOW_STORAGE_DIR=./data/uploads
